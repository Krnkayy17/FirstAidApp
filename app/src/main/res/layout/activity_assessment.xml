<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    tools:context=".AssessmentActivity">

    <!-- Optional Toolbar -->
    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/nav_background"
        android:title="Assessments"
        android:titleTextColor="@android:color/black" />

    <!-- Assessment Banner -->
    <ImageView
        android:id="@+id/imgAssessmentBanner"
        android:layout_width="match_parent"
        android:layout_height="200dp"
        android:src="@drawable/quiz_image"
        android:scaleType="fitCenter"
        android:contentDescription="Assessment Banner"
        android:layout_marginBottom="12dp"/>

    <!-- Title -->
    <TextView
        android:id="@+id/tvAssessmentHeader"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Choose a module to begin the assessment:"
        android:textSize="16sp"
        android:padding="16dp"
        android:textColor="@color/black" />

    <TextView
        android:id="@+id/tvPassInfo"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="📌 Pass Requirement Info"
        android:textColor="@color/black"
        android:textSize="14sp"
        android:layout_marginBottom="8dp"/>


    <!-- RecyclerView for Assessment Cards -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerAssessments"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:paddingHorizontal="8dp"
        android:clipToPadding="false"
        android:overScrollMode="never" />

    <!-- Bottom Navigation -->
    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottom_navigation"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/nav_background"
        app:menu="@menu/bottom_nav_menu"
        app:labelVisibilityMode="selected"
        app:itemIconTint="@color/nav_selector"
        app:itemTextColor="@color/nav_selector" />

</LinearLayout>
