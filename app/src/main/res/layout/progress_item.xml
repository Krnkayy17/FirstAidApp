<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="@android:color/white"
    android:layout_marginBottom="12dp"
    android:elevation="2dp">

    <TextView
        android:id="@+id/tvProgressModuleTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Module Title"
        android:textSize="18sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/tvProgressStatus"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Status: Not Started"
        android:textSize="14sp"
        android:layout_marginTop="4dp" />

    <TextView
        android:id="@+id/tvProgressScore"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Score: --"
        android:textSize="14sp"
        android:layout_marginTop="2dp" />

    <ProgressBar
        android:id="@+id/progressTrackingBar"
        style="@android:style/Widget.ProgressBar.Horizontal"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:progress="0"
        android:max="100" />

    <ImageView
        android:id="@+id/imgProgressBadge"
        android:layout_width="60dp"
        android:layout_height="60dp"
        android:layout_gravity="end"
        android:src="@drawable/ic_trophy"
        android:contentDescription="Achievement Badge"
        android:visibility="gone"
        android:layout_marginTop="8dp" />
</LinearLayout>
