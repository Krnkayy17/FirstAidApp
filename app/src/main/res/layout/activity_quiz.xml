<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp"
    tools:context=".QuizActivity">

    <LinearLayout
        android:id="@+id/quizContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- 🔹 Question Progress -->
        <TextView
            android:id="@+id/tv_question_number"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Question 1 of 10"
            android:textStyle="bold"
            android:textSize="16sp" />

        <!-- 🔸 MCQ Layout -->
        <LinearLayout
            android:id="@+id/layout_mcq"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone">

            <TextView
                android:id="@+id/tv_mcq_question_text"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="MCQ Question Text"
                android:textSize="18sp"
                android:textStyle="bold"
                android:layout_marginTop="12dp" />

            <ImageView
                android:id="@+id/img_mcq_question"
                android:layout_width="match_parent"
                android:layout_height="180dp"
                android:layout_marginVertical="12dp"
                android:scaleType="fitCenter"
                android:visibility="gone" />

            <RadioGroup
                android:id="@+id/rg_mcq_options"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical" />
        </LinearLayout>

        <!-- 🔸 Scenario Layout -->
        <LinearLayout
            android:id="@+id/layout_scenario"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone"
            android:layout_marginTop="16dp">

            <TextView
                android:id="@+id/tv_scenario_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Scenario Title"
                android:textSize="18sp"
                android:textStyle="bold" />

            <ImageView
                android:id="@+id/img_scenario"
                android:layout_width="match_parent"
                android:layout_height="180dp"
                android:layout_marginTop="12dp"
                android:scaleType="fitCenter"
                android:visibility="gone" />

            <TextView
                android:id="@+id/tv_scenario_instruction"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Arrange the steps below."
                android:layout_marginTop="8dp" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recycler_scenario_steps"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:background="#F5F5F5"
                android:padding="8dp" />
        </LinearLayout>

        <!-- 🔘 Navigation + Action Buttons -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="24dp"
            android:gravity="end">

            <Button
                android:id="@+id/btn_previous_question"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Previous"
                android:backgroundTint="#CCCCCC" />

            <Space
                android:layout_width="12dp"
                android:layout_height="wrap_content" />

            <Button
                android:id="@+id/btn_next_submit"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Next"
                android:backgroundTint="@color/red" />
        </LinearLayout>

    </LinearLayout>
</ScrollView>
